let size = 1000000
let global_var = 42

func test_lookups() {
    let start_time = clock()
    let local_var = 10
    let sum_val = 0
    let i = 0
    
    while (i < size) {
        sum_val = sum_val + local_var + global_var
        i = i + 1
    }
    
    let end_time = clock()
    print("Luna Env Lookup Time: ", end_time - start_time, " seconds")
}

test_lookups()
