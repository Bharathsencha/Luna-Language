let a = [1, 2, 3]
let b = a
a[0] = 99

if (b[0] == 99) {
    print("SUCCESS: Reference Counting works! b is referencing a instead of copying.")
} else {
    print("FAILED: Deep copying is still occurring!")
    assert(false)
}

// Test loops with massive lists to verify no memory leaks happen
let i = 0
while (i < 100) {
    let big_list = [i, i+1, i+2, i+3]
    let s = "hello world " + to_string(i)
    i = i + 1
}
print("Loops finished.")
