print("Testing File I/O...")

let filename = "test_output.txt"

if (file_exists(filename)) {
    remove_file(filename)
}

let f = open(filename, "w")
assert(f)
assert(write(f, "Hello Luna\nSecond Line\n"))
close(f)

func write_with_defer(path, text) {
    let handle = open(path, "w")
    assert(handle)
    defer(close(handle))
    assert(write(handle, text))
}

write_with_defer(filename, "Deferred Hello\n")

assert(file_exists(filename))

f = open(filename, "r")
assert(f)
let content = read(f)
assert(str_len(content) > 0)
assert(content == "Deferred Hello\n")
close(f)

f = open(filename, "r")
let line1 = read_line(f)
let line2 = read_line(f)
close(f)

assert(str_len(line1) > 0)
assert(line2 == null)

assert(remove_file(filename))
assert(not file_exists(filename))

print("File I/O Tests Passed!")
